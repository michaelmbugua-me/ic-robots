{
  "name": "icmarkets-scalping-bot",
  "version": "1.0.0",
  "description": "AI forex scalping bot — Local Ollama AI + IC Markets cTrader Open API",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "auth": "node auth.js",
    "symbols": "node get-symbols.js",
    "start": "node index.js",
    "auto": "SESSION_WINDOW_MODE=all_windows EMA_SEPARATION_MIN_PIPS=0.5 node index.js --auto-execute",
    "download": "node download-history.js",
    "download:eurusd:3y": "node download-history.js --pair EUR_USD --days 1095 --resume --chunk-size 2500",
    "backtest": "node backtest-multi.js",
    "backtest:ny-orb": "STRATEGY_MODE=ny_orb SESSION_WINDOW_MODE=all_windows node backtest-multi.js",
    "backtest:session-sweep": "STRATEGY_MODE=session_sweep SESSION_WINDOW_MODE=all_windows node backtest-multi.js",
    "backtest:ny-asian": "STRATEGY_MODE=ny_asian_continuation SESSION_WINDOW_MODE=all_windows node backtest-multi.js",
    "backtest:ny-asian:multi": "TRADING_PAIRS=EUR_USD,GBP_USD,USD_JPY STRATEGY_MODE=ny_asian_continuation SESSION_WINDOW_MODE=all_windows node backtest-multi.js",
    "backtest:smash": "STRATEGY_MODE=smash SESSION_WINDOW_MODE=all_windows node backtest-multi.js",
    "backtest:smash-buy": "STRATEGY_MODE=smash_buy SESSION_WINDOW_MODE=all_windows node backtest-multi.js",
    "backtest:smash-sell": "STRATEGY_MODE=smash_sell SESSION_WINDOW_MODE=all_windows node backtest-multi.js",
    "backtest:ny": "SESSION_WINDOW_MODE=ny_only node backtest-multi.js",
    "backtest:ny-quality": "SESSION_WINDOW_MODE=ny_quality EMA_SEPARATION_MIN_PIPS=0.5 node backtest-multi.js",
    "backtest:ny-trim": "SESSION_WINDOW_MODE=ny_trimmed node backtest-multi.js",
    "backtest:all": "SESSION_WINDOW_MODE=all_windows EMA_SEPARATION_MIN_PIPS=0.5 node backtest-multi.js",
    "start:ny-quality": "SESSION_WINDOW_MODE=ny_quality EMA_SEPARATION_MIN_PIPS=0.5 node index.js",
    "auto:ny-quality": "SESSION_WINDOW_MODE=ny_quality EMA_SEPARATION_MIN_PIPS=0.5 node index.js --auto-execute",
    "start:ny-asian": "STRATEGY_MODE=ny_asian_continuation SESSION_WINDOW_MODE=all_windows node index.js",
    "auto:ny-asian": "STRATEGY_MODE=ny_asian_continuation SESSION_WINDOW_MODE=all_windows node index.js --auto-execute",
    "compare:modes": "node compare-modes.js",
    "compare:modes:prune": "node prune-mode-snapshots.js",
    "compare:modes:run": "node compare-modes.js && node prune-mode-snapshots.js",
    "research:regimes": "node market-regime-analysis.js",
    "backtest-multi-mock": "node backtest-multi.js --mock",
    "backtest-mock": "node backtest.js --mock",
    "gbp": "node index.js --pair GBP_USD",
    "gbp-auto": "node index.js --pair GBP_USD --auto-execute",
    "jpn": "node index.js --pair USD_JPY",
    "jpn-auto": "node index.js --pair USD_JPY --auto-execute",
    "analyze": "node trade-analyzer.js && node generate-report.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ic-scalping-bot",
    "pm2:restart": "pm2 restart ic-scalping-bot",
    "pm2:logs": "pm2 logs ic-scalping-bot",
    "pm2:status": "pm2 status",
    "pm2:kill": "pm2 kill",
    "pm2:delete": "pm2 delete ic-scalping-bot"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "long": "^5.3.2",
    "protobufjs": "^8.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "pm2": "^5.4.3"
  }
}
