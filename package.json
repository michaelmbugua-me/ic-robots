{
  "name": "icmarkets-scalping-bot",
  "version": "1.0.0",
  "description": "Forex scalping bot — IC Markets cTrader Open API",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "auth": "node auth.js",
    "symbols": "node get-symbols.js",
    "start": "node index.js",
    "auto": "STRATEGY_MODE=combined_ny_london SESSION_WINDOW_MODE=all_windows LONDON_MONITOR_ENABLED=true LONDON_FAKE_BREAK_TRADE_END_UTC=9 LONDON_FAKE_BREAK_ALLOWED_WEEKDAYS=Wed LONDON_FAKE_BREAK_ALLOWED_PAIRS=EUR_USD,USD_JPY LONDON_MAX_LOSSES_PER_DAY=1 node index.js --auto-execute",
    "download": "node download-history.js",
    "download:eurusd:3y": "node download-history.js --pair EUR_USD --days 1095 --resume --chunk-size 2500",
    "download:usdjpy:3y": "node download-history.js --pair USD_JPY --days 1095 --resume --chunk-size 2500",
    "download:gbpusd:3y": "node download-history.js --pair GBP_USD --days 1095 --resume --chunk-size 2500",
    "backtest": "node backtest-multi.js",
    "analyze": "node trade-analyzer.js && node generate-report.js",
    "backtest:ny-asian": "STRATEGY_MODE=ny_asian_continuation SESSION_WINDOW_MODE=all_windows node backtest-multi.js",
    "backtest:ny-asian:multi": "TRADING_PAIRS=EUR_USD,GBP_USD,USD_JPY STRATEGY_MODE=ny_asian_continuation SESSION_WINDOW_MODE=all_windows node backtest-multi.js",
    "backtest:london-fake-break": "STRATEGY_MODE=london_asian_fake_break_reversal SESSION_WINDOW_MODE=london_only node backtest-multi.js",
    "backtest:london-fake-break:multi": "TRADING_PAIRS=EUR_USD,GBP_USD,USD_JPY STRATEGY_MODE=london_asian_fake_break_reversal SESSION_WINDOW_MODE=london_only node backtest-multi.js",
    "backtest:london-fake-break:usdjpy": "TRADING_PAIRS=USD_JPY STRATEGY_MODE=london_asian_fake_break_reversal SESSION_WINDOW_MODE=london_only node backtest-multi.js",
    "backtest:london-fake-break:eurusd-usdjpy": "TRADING_PAIRS=EUR_USD,USD_JPY STRATEGY_MODE=london_asian_fake_break_reversal SESSION_WINDOW_MODE=london_only node backtest-multi.js",
    "backtest:london-fake-break:usdjpy:braked": "TRADING_PAIRS=USD_JPY LONDON_MAX_LOSSES_PER_DAY=1 STRATEGY_MODE=london_asian_fake_break_reversal SESSION_WINDOW_MODE=london_only node backtest-multi.js",
    "backtest:london-fake-break:eurusd-usdjpy:braked": "TRADING_PAIRS=EUR_USD,USD_JPY LONDON_MAX_LOSSES_PER_DAY=1 STRATEGY_MODE=london_asian_fake_break_reversal SESSION_WINDOW_MODE=london_only node backtest-multi.js",
    "backtest:london-fake-break:usdjpy:cleaned": "TRADING_PAIRS=USD_JPY LONDON_FAKE_BREAK_TRADE_END_UTC=9 LONDON_MAX_LOSSES_PER_DAY=1 STRATEGY_MODE=london_asian_fake_break_reversal SESSION_WINDOW_MODE=london_only node backtest-multi.js",
    "backtest:london-fake-break:eurusd-usdjpy:cleaned": "TRADING_PAIRS=EUR_USD,USD_JPY LONDON_FAKE_BREAK_TRADE_END_UTC=9 LONDON_FAKE_BREAK_ALLOWED_WEEKDAYS=Wed LONDON_MAX_LOSSES_PER_DAY=1 STRATEGY_MODE=london_asian_fake_break_reversal SESSION_WINDOW_MODE=london_only node backtest-multi.js",
    "backtest:london-fake-break:a": "LONDON_FAKE_BREAK_PROFILE=candidate_a_time_exit STRATEGY_MODE=london_asian_fake_break_reversal SESSION_WINDOW_MODE=london_only node backtest-multi.js",
    "backtest:london-fake-break:a:multi": "TRADING_PAIRS=EUR_USD,GBP_USD,USD_JPY LONDON_FAKE_BREAK_PROFILE=candidate_a_time_exit STRATEGY_MODE=london_asian_fake_break_reversal SESSION_WINDOW_MODE=london_only node backtest-multi.js",
    "backtest:london-fake-break:a:usdjpy": "TRADING_PAIRS=USD_JPY LONDON_FAKE_BREAK_PROFILE=candidate_a_time_exit STRATEGY_MODE=london_asian_fake_break_reversal SESSION_WINDOW_MODE=london_only node backtest-multi.js",
    "backtest:london-fake-break:a:eurusd-usdjpy": "TRADING_PAIRS=EUR_USD,USD_JPY LONDON_FAKE_BREAK_PROFILE=candidate_a_time_exit STRATEGY_MODE=london_asian_fake_break_reversal SESSION_WINDOW_MODE=london_only node backtest-multi.js",
    "start:ny-asian": "STRATEGY_MODE=ny_asian_continuation SESSION_WINDOW_MODE=all_windows node index.js",
    "start:london-monitor:cleaned": "TRADING_PAIRS=EUR_USD,USD_JPY STRATEGY_MODE=london_asian_fake_break_reversal SESSION_WINDOW_MODE=london_only LONDON_MONITOR_ENABLED=true LONDON_FAKE_BREAK_TRADE_END_UTC=9 LONDON_FAKE_BREAK_ALLOWED_WEEKDAYS=Wed LONDON_MAX_LOSSES_PER_DAY=1 node index.js",
    "auto:ny-asian": "STRATEGY_MODE=ny_asian_continuation SESSION_WINDOW_MODE=all_windows node index.js --auto-execute",
    "research:regimes": "node market-regime-analysis.js",
    "research:london-fake-break": "node market-regime-analysis.js",
    "research:london-fake-break:sweep": "node market-regime-analysis.js --london-fake-break-sweep",
    "research:london-fake-break:compare": "node compare-london-fake-break-sweeps.js",
    "research:london-fake-break:variants": "node analyze-london-variants.js",
    "research:london-ny:correlation": "node analyze-london-ny-correlation.js",
    "research:london:diagnostics": "node analyze-london-diagnostics.js",
    "research:combined:selected": "node analyze-selected-combination.js",
    "research:london:improvements": "node run-london-improvement-backtests.js",
    "test": "node tests/indicators-london-fake-break.test.js && node tests/risk-manager.test.js && node tests/package-sanity.test.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ic-scalping-bot",
    "pm2:restart": "pm2 restart ic-scalping-bot",
    "pm2:logs": "pm2 logs ic-scalping-bot",
    "pm2:status": "pm2 status",
    "pm2:kill": "pm2 kill",
    "pm2:delete": "pm2 delete ic-scalping-bot"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "long": "^5.3.2",
    "protobufjs": "^8.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "pm2": "7.0.0"
  }
}
