
  // --- STRATEGY OVERHAUL: "So Easy It's Ridiculous" ---
  async function tickPair(pair, timestamp) {
    const state = getState(pair);
    const now = Date.now();

    // 1. Fetch Candles (M5 Tactical + H1 Strategic)
    if (state.needsRefresh || state.candleCache.length < 50) {
      state.candleCache = await icmarkets.getCandles(pair, config.granularity, 200);
      state.needsRefresh = false;
    }
    const baseCandles = state.candleCache;

    if (!state.lastHeavyFetch || (now - state.lastHeavyFetch > 60000)) {
      state.htfCandles = await icmarkets.getCandles(pair, config.htfGranularity, 200).catch(() => null);
      state.lastHeavyFetch = now;
    }
    if (!baseCandles || !state.htfCandles) return;

    // 2. Phase 1: Risk & Spread
    const riskCheck = riskManager.canTrade();
    if (!riskCheck.allowed) return;

    if (state.lastBid && state.lastAsk) {
      const isJPY = pair.includes("JPY");
      const pipSize = isJPY ? 0.01 : 0.0001;
      const spread = (state.lastAsk - state.lastBid) / pipSize;
      if (spread > config.maxSpreadPips) return;
    }

    // 3. Phase 2: Indicators
    const indicators = calculateIndicators(baseCandles);
    const htfIndicators = calculateIndicators(state.htfCandles);

    // Manage existing trades (SL/TP, Trailing)
    await manageActiveTrades(pair, indicators);

    const shouldLog = (now - (state.lastLogTime || 0)) > 60000;

    // 4. Phase 3: "Bird's Eye View" (Strategic Filter)
    // Identify trend on H1: Is market moving up, down? (EMA 5 vs 10 on H1)
    const htfTrend = htfIndicators.ema5 > htfIndicators.ema10 ? "BULLISH" : "BEARISH";

    // 5. Phase 4: Tactical Entry (M5 Setup)
    let action = "WAIT";

    // LONG: 5 EMA > 10 EMA + Stoch Heading Up (Not OB) + RSI > 50 + H1 Trend Bullish
    const isBuySetup = indicators.ema5 > indicators.ema10 &&
                       indicators.isStochHeadingUp &&
                       !indicators.isStochOverbought &&
                       indicators.rsi > 50 &&
                       htfTrend === "BULLISH";

    // SHORT: 5 EMA < 10 EMA + Stoch Heading Down (Not OS) + RSI < 50 + H1 Trend Bearish
    const isSellSetup = indicators.ema5 < indicators.ema10 &&
                        indicators.isStochHeadingDown &&
                        !indicators.isStochOversold &&
                        indicators.rsi < 50 &&
                        htfTrend === "BEARISH";

    if (isBuySetup) action = "BUY";
    if (isSellSetup) action = "SELL";

    if (shouldLog) {
      console.log(`[${timestamp}] ${pair} | H1:${htfTrend} | RSI:${indicators.rsi?.toFixed(1)} STOCH:${indicators.stochK?.toFixed(1)} EMA5/10:${indicators.ema5?.toFixed(5)}/${indicators.ema10?.toFixed(5)}`);
      state.lastLogTime = now;
    }

    if (action === "WAIT") return;

    // 6. Execution
    const { atrMultiplierSL, atrMultiplierTP } = config.strategy;
    const slDist = (atrMultiplierSL || 3.0) * indicators.atr;
    const tpDist = (atrMultiplierTP || 6.0) * indicators.atr;
    const px = indicators.currentPrice;

    const signal = {
      action,
      confidence: 100,
      sentiment: action === "BUY" ? "Bullish" : "Bearish",
      sentimentScore: 100,
      entry: px,
      stopLoss:   action === "BUY" ? px - slDist : px + slDist,
      takeProfit: action === "BUY" ? px + tpDist : px - tpDist,
      reasoning: "So Easy It's Ridiculous Setup (School of Pipsology)"
    };

    console.log(`\n[${timestamp}] ⚡ ${pair} ${action} Signal Triggered!`);
    await processSignal(pair, signal, indicators, timestamp, htfIndicators, "0.0", [action, "WAIT"]);
  }
