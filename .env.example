# cTrader Open API credentials
# Register an app at https://openapi.ctrader.com and use auth.js to generate tokens.
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_ACCOUNT_ID=
CTRADER_ACCESS_TOKEN=
# Optional: auth.js prints this, but the current runtime reads CTRADER_ACCESS_TOKEN only.
CTRADER_REFRESH_TOKEN=

# demo or live. Start with demo.
CTRADER_ENV=demo

# Runtime scope
TRADING_PAIRS=EUR_USD,GBP_USD,USD_JPY,AUD_USD,USD_CAD,NZD_USD
# ny_asian_continuation, london_asian_fake_break_reversal, or combined_ny_london.
STRATEGY_MODE=ny_asian_continuation
SESSION_WINDOW_MODE=all_windows

# Risk controls
RISK_PER_TRADE_PERCENT=1.0
ENFORCE_DAILY_STOP_LOSS=true
DAILY_STOP_LOSS_KES=12000
DAILY_PROFIT_TARGET_KES=20000
MAX_TOTAL_TRADES=3
MAX_TRADES_PER_PAIR=1
MAX_SLIPPAGE_PIPS=0.5

# Execution guards
USE_BROKER_STOP_ORDERS=true
FALLBACK_TO_LOCAL_STOPS=false
MAX_SPREAD_PIPS=1.5
MAX_QUOTE_AGE_MS=5000
DEBUG_ORDER_PAYLOAD=false

# cTrader non-trade request throttling
CTRADER_NON_TRADE_MIN_INTERVAL_MS=750
CTRADER_MAX_NON_TRADE_REQUESTS_PER_MINUTE=40
CTRADER_RATE_LIMIT_BACKOFF_MS=30000

# NY Asian continuation strategy
NY_ASIAN_ALLOWED_SESSIONS=ny_overlap
NY_ASIAN_START_UTC=0
NY_ASIAN_END_UTC=7
NY_ASIAN_TRADE_START_UTC=12.5
NY_ASIAN_TRADE_END_UTC=15.5
NY_ASIAN_PREFER_AFTER_UTC=13.0
NY_ASIAN_FORCE_EXIT_UTC=16.0
NY_ASIAN_REQUIRE_H1_ALIGNMENT=true
NY_ASIAN_ENTRY_BUFFER_PIPS=0.5
NY_ASIAN_STOP_BUFFER_PIPS=0.5
NY_ASIAN_MIN_BREAK_PIPS=3.0
NY_ASIAN_MIN_RISK_PIPS=5
NY_ASIAN_MAX_RISK_PIPS=15
NY_ASIAN_RR_RATIO=2.0
NY_ASIAN_PENDING_EXPIRY_BARS=3
NY_ASIAN_TIME_EXIT_BARS=12
NY_ASIAN_MAX_TRADES_PER_SESSION=1
NY_ASIAN_LOOKBACK_CANDLES=220
COOLDOWN_CANDLES_AFTER_LOSS=1

# Per-pair overrides (override baseline for specific pairs)
# Format: NY_ASIAN_{PAIR}_{PARAM}
# Supported params: RR_RATIO, MIN_BREAK_PIPS, MIN_RISK_PIPS, MAX_RISK_PIPS
# Example: NY_ASIAN_EUR_USD_RR_RATIO=2.5
# Example: NY_ASIAN_GBP_USD_MIN_BREAK_PIPS=4

# London Asian fake-break reversal strategy (disabled by default — underperformed in backtests).
# Monitor-only by default unless LONDON_LIVE_EXECUTION_ENABLED=true is explicitly set.
LONDON_MONITOR_ENABLED=false
LONDON_LIVE_EXECUTION_ENABLED=false
LONDON_FAKE_BREAK_PROFILE=candidate_b
LONDON_FAKE_BREAK_ALLOWED_SESSIONS=london_open
LONDON_FAKE_BREAK_ALLOWED_PAIRS=
LONDON_FAKE_BREAK_ALLOWED_WEEKDAYS=Wed
LONDON_FAKE_BREAK_EXCLUDED_PAIR_WEEKDAYS=
LONDON_FAKE_BREAK_ASIAN_START_UTC=0
LONDON_FAKE_BREAK_ASIAN_END_UTC=7
LONDON_FAKE_BREAK_TRADE_START_UTC=7.0
LONDON_FAKE_BREAK_TRADE_END_UTC=9.0
LONDON_FAKE_BREAK_MIN_BREAK_PIPS=4.0
LONDON_FAKE_BREAK_CONFIRM_BARS=2
LONDON_FAKE_BREAK_STOP_BUFFER_PIPS=0.5
LONDON_FAKE_BREAK_MIN_RISK_PIPS=5
LONDON_FAKE_BREAK_MAX_RISK_PIPS=10
LONDON_FAKE_BREAK_TARGET_MODE=time_exit
LONDON_FAKE_BREAK_H1_FILTER=all
LONDON_FAKE_BREAK_TIME_EXIT_BARS=12
LONDON_FAKE_BREAK_MAX_TRADES_PER_SESSION=1
LONDON_MAX_LOSSES_PER_DAY=1
LONDON_MAX_DAILY_LOSS_USD=0
LONDON_FAKE_BREAK_LOOKBACK_CANDLES=220

# Backtest assumptions
BACKTEST_SPREAD_PIPS=0.7
BACKTEST_SLIPPAGE_PIPS=0.3
